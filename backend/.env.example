# Server settings (all optional, defaults shown)
HOST=127.0.0.1
PORT=8000
ALLOWED_ORIGINS=https://kraken.expertintheloop.io
RATE_LIMIT_PER_MINUTE=10
# CLAUDE_MODEL=sonnet  # Optional: use "sonnet", "opus", or full model ID

# Authentication is handled via Claude CLI OAuth (run `claude login` on server).
# ANTHROPIC_API_KEY can be set as a fallback for API key authentication.

# Kestrel MCP Server (required for knowledge graph access)
KESTREL_API_KEY=your-kestrel-api-key-here
# KESTREL_MCP_URL=https://kestrel.nathanpricelab.com/mcp  # Optional, defaults to production

# Database (optional, for conversation persistence)
# DATABASE_URL=postgresql://user:password@localhost:5432/kraken_db

# Clerk Authentication
# Set CLERK_AUTH_ENABLED=true and provide CLERK_SECRET_KEY to enable auth.
# When enabled without a secret key, the app logs a critical warning.
# Set CLERK_AUTH_ENABLED=false for local development without Clerk.
CLERK_AUTH_ENABLED=false
# CLERK_SECRET_KEY=sk_test_or_sk_live_your-key
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_PROXY_URL=https://your-domain.com/api/__clerk
# ALLOWED_EMAIL_DOMAINS=phenomehealth.org
# ALLOWED_EMAILS=user@example.com
